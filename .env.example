# Next.js Environment Variables
# Socket.IO Server URL for video calls
# For local development, use: http://localhost:3001
# For production (Render), use your Render service URL, e.g.: https://your-service.onrender.com

NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# MongoDB Configuration
# For local development with MongoDB installed:
MONGODB_URI=mongodb+srv://Ramzi:16716@autismcare.ir29elb.mongodb.net/autismcare?retryWrites=true&w=majority&appName=AutismCare

# For MongoDB Atlas, use format:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# DNS servers for MongoDB Atlas SRV DNS resolution (optional, helps with IPv6 DNS issues)
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1