{
  "project": "Autism Chatbot System",
  "description": "A comprehensive chatbot for answering autism-related questions with text and image analysis capabilities",
  "models": {
    "text_model": {
      "type": "LSTM-based decoder (simulating LLaMA/Mistral architecture)",
      "vocab_size": 10000,
      "embed_dim": 256,
      "hidden_dim": 512,
      "num_layers": 2
    },
    "image_model": {
      "type": "Vision Transformer with ResNet backbone (simulating ViT/Swin Transformer)",
      "embed_dim": 512,
      "num_heads": 8,
      "num_layers": 6,
      "num_classes": 2,
      "input_size": [224, 224]
    }
  },
  "training": {
    "text_epochs": 100,
    "batch_size": 8,
    "learning_rate": 0.001,
    "optimizer": "Adam"
  },
  "data": {
    "text_data_path": "../../autism_question_bot_data_formatted.txt",
    "image_data_dir": "../image data",
    "autistic_images": 1470,
    "non_autistic_images": 1440,
    "total_images": 2910
  },
  "features": {
    "text_qa": true,
    "image_analysis": true,
    "interactive_chat": true,
    "metrics_reporting": true
  }
}
